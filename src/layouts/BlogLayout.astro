---
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  tags: string[];
}

const { title, description, date, author, tags } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — G8Stack Blog`} description={description}>
  <Navbar />
  <main class="pt-32 pb-20">
    <Container>
      <article class="max-w-3xl mx-auto">
        <header class="mb-12">
          <div class="flex flex-wrap gap-2 mb-4">
            {tags.map((tag) => (
              <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
                {tag}
              </span>
            ))}
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">{title}</h1>
          <p class="text-lg text-slate-400 mb-6">{description}</p>
          <div class="flex items-center gap-3 text-sm text-slate-500">
            <span>{author}</span>
            <span>&middot;</span>
            <time datetime={date.toISOString()}>{formattedDate}</time>
          </div>
        </header>

        <div class="prose prose-invert prose-slate max-w-none prose-headings:text-white prose-p:text-slate-400 prose-li:text-slate-400 prose-a:text-blue-400 prose-strong:text-slate-300 prose-code:text-blue-300">
          <slot />
        </div>
      </article>
    </Container>
  </main>
  <Footer />
</BaseLayout>
