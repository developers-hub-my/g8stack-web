---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Privacy Policy — G8Stack" description="G8Stack privacy policy. Learn how we collect, use, and protect your data.">
  <Navbar />
  <main class="pt-32 pb-20">
    <Container>
      <div class="max-w-3xl mx-auto prose prose-invert prose-slate">
        <h1 class="text-4xl font-bold text-white mb-2">Privacy Policy</h1>
        <p class="text-slate-500 text-sm mb-12">Last updated: February 2026</p>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">1. Introduction</h2>
          <p class="text-slate-400 leading-relaxed">
            G8Stack is a product of Developers Hub Sdn Bhd ("we", "our", "us"). This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website at g8stack.com or use our platform.
          </p>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">2. Information We Collect</h2>
          <p class="text-slate-400 leading-relaxed mb-4">We may collect the following types of information:</p>
          <ul class="list-disc list-inside text-slate-400 space-y-2">
            <li><strong class="text-slate-300">Contact information:</strong> Name, email address, company name, and phone number when you contact us or request a demo.</li>
            <li><strong class="text-slate-300">Usage data:</strong> Pages visited, time spent, browser type, and referring URLs collected through analytics.</li>
            <li><strong class="text-slate-300">Account data:</strong> Login credentials and profile information when you create a G8Stack account.</li>
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">3. How We Use Your Information</h2>
          <ul class="list-disc list-inside text-slate-400 space-y-2">
            <li>To provide and maintain the G8Stack platform</li>
            <li>To respond to your inquiries and support requests</li>
            <li>To send product updates and relevant communications</li>
            <li>To improve our website and services</li>
            <li>To comply with legal obligations</li>
          </ul>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">4. Data Sharing</h2>
          <p class="text-slate-400 leading-relaxed">
            We do not sell your personal information. We may share data with trusted service providers who assist in operating our platform (hosting, analytics, email), subject to confidentiality agreements.
          </p>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">5. Data Security</h2>
          <p class="text-slate-400 leading-relaxed">
            We implement appropriate technical and organizational measures to protect your personal data. However, no method of transmission over the Internet is 100% secure.
          </p>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">6. Your Rights</h2>
          <p class="text-slate-400 leading-relaxed">
            You have the right to access, correct, or delete your personal data. To exercise these rights, contact us at hello@devhub.my.
          </p>
        </section>

        <section class="mb-10">
          <h2 class="text-xl font-semibold text-white mb-4">7. Contact Us</h2>
          <p class="text-slate-400 leading-relaxed">
            If you have questions about this Privacy Policy, contact us at:<br />
            <a href="mailto:hello@devhub.my" class="text-blue-400 hover:text-blue-300">hello@devhub.my</a>
          </p>
        </section>
      </div>
    </Container>
  </main>
  <Footer />
</BaseLayout>
