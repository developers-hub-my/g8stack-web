---
interface Props {
  label?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { label, title, description, align = "center" } = Astro.props;

const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class:list={["max-w-3xl mb-16", alignClass]} data-aos="fade-up">
  {
    label && (
      <span class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse-dot" />
        {label}
      </span>
    )
  }
  <h2
    class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4"
    set:html={title}
  />
  {description && <p class="text-lg text-slate-400">{description}</p>}
</div>
