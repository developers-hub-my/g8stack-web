---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium bg-blue-500/10 text-blue-400 border border-blue-500/20",
    className,
  ]}
>
  <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse-dot"></span>
  <slot />
</span>
