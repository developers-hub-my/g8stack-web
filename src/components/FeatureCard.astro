---
import SubscriptionIcon from "./icons/SubscriptionIcon.astro";
import KeyIcon from "./icons/KeyIcon.astro";
import RateLimitIcon from "./icons/RateLimitIcon.astro";
import ApprovalIcon from "./icons/ApprovalIcon.astro";
import DocsIcon from "./icons/DocsIcon.astro";
import AnalyticsIcon from "./icons/AnalyticsIcon.astro";
import SyncIcon from "./icons/SyncIcon.astro";
import PluginsIcon from "./icons/PluginsIcon.astro";
import UsersIcon from "./icons/UsersIcon.astro";
import RoutesIcon from "./icons/RoutesIcon.astro";
import ShieldIcon from "./icons/ShieldIcon.astro";
import LogsIcon from "./icons/LogsIcon.astro";

interface Props {
  icon: string;
  title: string;
  description: string;
  delay?: number;
}

const { icon, title, description, delay = 0 } = Astro.props;

const iconMap: Record<string, any> = {
  subscription: SubscriptionIcon,
  key: KeyIcon,
  rateLimit: RateLimitIcon,
  approval: ApprovalIcon,
  docs: DocsIcon,
  analytics: AnalyticsIcon,
  sync: SyncIcon,
  plugins: PluginsIcon,
  users: UsersIcon,
  routes: RoutesIcon,
  shield: ShieldIcon,
  logs: LogsIcon,
};

const IconComponent = iconMap[icon];
---

<div
  class="glass-card rounded-xl p-6 transition-all duration-300 hover:translate-y-[-2px] group"
  data-aos="fade-up"
  data-aos-delay={delay}
>
  <div
    class="w-12 h-12 rounded-lg bg-gradient-to-br from-blue-500/20 to-violet-500/20 flex items-center justify-center mb-4 group-hover:from-blue-500/30 group-hover:to-violet-500/30 transition-colors"
  >
    {IconComponent && <IconComponent class="w-6 h-6 text-blue-400" />}
  </div>
  <h3 class="text-lg font-semibold text-white mb-2">{title}</h3>
  <p class="text-sm text-slate-400 leading-relaxed">{description}</p>
</div>
