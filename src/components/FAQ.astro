---
import Container from "./ui/Container.astro";
import SectionHeading from "./ui/SectionHeading.astro";

const faqs = [
  {
    question: "What API gateways does G8Stack support?",
    answer:
      "G8Stack currently supports Kong and Apache APISIX, with more gateway integrations on the roadmap. It connects to your existing gateway instance — no migration needed.",
  },
  {
    question: "Does G8Stack replace my API gateway?",
    answer:
      "No. G8Stack is a management layer that sits on top of your existing API gateway. Your traffic continues to flow through your gateway as usual — G8Stack provides the dashboard to manage it.",
  },
  {
    question: "How long does it take to set up?",
    answer:
      "Most teams are up and running in under 30 minutes. Point G8Stack to your gateway, and it automatically discovers your existing services, routes, and plugins.",
  },
  {
    question: "Can non-technical team members use G8Stack?",
    answer:
      "Yes — that's one of the core benefits. G8Stack's visual dashboard lets product managers, team leads, and other stakeholders manage API access and view analytics without needing CLI or DevOps expertise.",
  },
  {
    question: "Is my data secure?",
    answer:
      "G8Stack can be deployed on your own infrastructure, so your data never leaves your environment. All actions are logged with a full audit trail, and access is controlled through role-based permissions.",
  },
  {
    question: "What kind of support is included?",
    answer:
      "Every plan includes dedicated onboarding and priority support. We work with your team to ensure a smooth setup and are available for ongoing technical guidance.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
};
---

<section id="faq" class="py-24 lg:py-32">
  <Container>
    <SectionHeading
      label="FAQ"
      title='Common <span class="text-gradient">questions</span>'
      description="Everything you need to know about G8Stack."
    />

    <div class="max-w-3xl mx-auto space-y-4">
      {
        faqs.map((faq, i) => (
          <details
            class="group glass-card rounded-xl overflow-hidden"
            data-aos="fade-up"
            data-aos-delay={i * 50}
          >
            <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-white font-medium text-sm sm:text-base list-none">
              {faq.question}
              <svg
                class="w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-45"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-slate-400 leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>
  </Container>

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
