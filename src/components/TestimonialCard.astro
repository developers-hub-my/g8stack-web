---
interface Props {
  quote: string;
  author: string;
  role: string;
  company: string;
  avatar: string;
  delay?: number;
}

const { quote, author, role, company, avatar, delay = 0 } = Astro.props;
---

<div
  class="glass-card rounded-xl p-6 lg:p-8"
  data-aos="fade-up"
  data-aos-delay={delay}
>
  <!-- Stars -->
  <div class="flex gap-1 mb-4">
    {
      Array(5)
        .fill(0)
        .map(() => (
          <svg
            class="w-4 h-4 text-yellow-400"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))
    }
  </div>

  <blockquote class="text-slate-300 text-sm leading-relaxed mb-6">
    "{quote}"
  </blockquote>

  <div class="flex items-center gap-3">
    <!-- Avatar -->
    <div
      class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-violet-500 flex items-center justify-center text-white text-xs font-bold"
    >
      {avatar}
    </div>
    <div>
      <p class="text-sm font-semibold text-white">{author}</p>
      <p class="text-xs text-slate-500">
        {role}, {company}
      </p>
    </div>
  </div>
</div>
