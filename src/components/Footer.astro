---
import Container from "./ui/Container.astro";

const footerLinks = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "#features" },
      { label: "How It Works", href: "#how-it-works" },
      { label: "Use Cases", href: "#use-cases" },
      { label: "Architecture", href: "#architecture" },
      { label: "Pricing", href: "#pricing" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About Us", href: "https://devhub.my" },
      { label: "Contact", href: "mailto:hello@devhub.my" },
    ],
  },
];
---

<footer class="border-t border-white/5 py-16">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-3 mb-4">
          <img src="/images/logo.svg" alt="G8Stack" class="h-8" />
        </a>
        <p class="text-sm text-slate-500 leading-relaxed mb-6">
          API Gateway Manager with a powerful web UI. Built by Developers Hub
          Sdn Bhd.
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          <a
            href="https://github.com/developers-hub-my"
            class="w-9 h-9 rounded-lg bg-white/5 border border-white/5 flex items-center justify-center text-slate-500 hover:text-white hover:border-white/10 transition-colors"
            aria-label="GitHub"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {
        footerLinks.map((column) => (
          <div>
            <h4 class="text-sm font-semibold text-white mb-4">
              {column.title}
            </h4>
            <ul class="space-y-3">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-500 hover:text-slate-300 transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-xs text-slate-600">
        &copy; {new Date().getFullYear()} Developers Hub Sdn Bhd. All rights
        reserved.
      </p>
      <p class="text-xs text-slate-600">
        G8Stack is a product of
        <a
          href="https://devhub.my"
          class="text-slate-500 hover:text-slate-300 transition-colors"
        >
          Developers Hub Sdn Bhd
        </a>
      </p>
    </div>
  </Container>
</footer>
