---
import Container from "./ui/Container.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import Button from "./ui/Button.astro";

const features = [
  "Unlimited API routes & services",
  "Full API gateway management",
  "Subscription & API key management",
  "Approval workflows & audit logs",
  "Real-time analytics dashboard",
  "Role-based access control",
  "Elasticsearch & Kibana integration",
  "Dedicated support & onboarding",
];
---

<section id="pricing" class="py-24 lg:py-32 relative">
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-500/[0.02] to-transparent pointer-events-none"
  >
  </div>

  <Container class="relative">
    <SectionHeading
      label="Pricing"
      title='Enterprise-grade API management'
      description="G8Stack is designed for organizations that need robust, governed API gateway management."
    />

    <div class="max-w-lg mx-auto" data-aos="fade-up">
      <div
        class="glass-card rounded-2xl p-8 lg:p-10 text-center glow-blue"
      >
        <span
          class="inline-block px-3 py-1 text-xs font-medium text-blue-400 bg-blue-500/10 rounded-full border border-blue-500/20 mb-6"
        >
          Enterprise
        </span>
        <h3 class="text-3xl font-bold text-white mb-2">Custom Pricing</h3>
        <p class="text-slate-400 mb-8">
          Tailored to your organization's size, requirements, and deployment
          model.
        </p>

        <ul class="space-y-3 text-left mb-8">
          {
            features.map((feature) => (
              <li class="flex items-center gap-3 text-sm text-slate-300">
                <svg
                  class="w-5 h-5 text-blue-400 shrink-0"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
                {feature}
              </li>
            ))
          }
        </ul>

        <Button href="mailto:hello@devhub.my" variant="primary" size="lg" class="w-full">
          Contact Us for Pricing
        </Button>
        <p class="text-xs text-slate-500 mt-4">
          Free consultation included. No commitment required.
        </p>
      </div>
    </div>
  </Container>
</section>
