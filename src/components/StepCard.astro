---
interface Props {
  step: number;
  title: string;
  description: string;
  delay?: number;
}

const { step, title, description, delay = 0 } = Astro.props;
---

<div class="relative text-center" data-aos="fade-up" data-aos-delay={delay}>
  <!-- Step number -->
  <div
    class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-violet-500 flex items-center justify-center mx-auto mb-6 text-2xl font-bold text-white"
  >
    {step}
  </div>
  <h3 class="text-xl font-semibold text-white mb-3">{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed max-w-xs mx-auto">
    {description}
  </p>
</div>
