---
import Container from "./ui/Container.astro";

const logos = [
  "TechCorp",
  "FinanceHub",
  "CloudScale",
  "DataFlow",
  "SecureNet",
  "APIFirst",
  "DevStream",
  "NetBridge",
];
---

<section class="py-16 border-y border-white/5">
  <Container>
    <p
      class="text-center text-sm text-slate-500 uppercase tracking-widest mb-8"
      data-aos="fade-up"
    >
      Trusted by engineering teams at
    </p>
    <div class="relative overflow-hidden">
      <!-- Fade edges -->
      <div
        class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-navy-950 to-transparent z-10"
      >
      </div>
      <div
        class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-navy-950 to-transparent z-10"
      >
      </div>

      <div class="flex animate-marquee">
        {
          [...logos, ...logos].map((name) => (
            <div class="flex items-center justify-center min-w-[180px] px-8 py-4">
              <span class="text-lg font-semibold text-slate-600 whitespace-nowrap">
                {name}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
