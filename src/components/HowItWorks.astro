---
import Container from "./ui/Container.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import StepCard from "./StepCard.astro";

const steps = [
  {
    title: "Connect",
    description:
      "Point G8Stack to your API gateway. It automatically discovers your existing setup — services, routes, and rules.",
  },
  {
    title: "Configure",
    description:
      "Set up access policies, approval workflows, and usage limits from the dashboard. Your whole team can participate.",
  },
  {
    title: "Scale",
    description:
      "Monitor traffic, track usage, and onboard new teams as you grow. G8Stack scales with your organization.",
  },
];
---

<section id="how-it-works" class="py-24 lg:py-32 relative">
  <!-- Background accent -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-500/[0.02] to-transparent pointer-events-none"
  >
  </div>

  <Container class="relative">
    <SectionHeading
      label="How It Works"
      title='Up and running <span class="text-gradient">in three steps</span>'
      description="Connect your gateway, configure your policies, and let your team take it from there."
    />

    <div class="relative max-w-4xl mx-auto">
      <!-- Connector line -->
      <div
        class="hidden md:block absolute top-8 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-blue-500/20 via-violet-500/40 to-blue-500/20"
      >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
        {
          steps.map((step, i) => (
            <StepCard
              step={i + 1}
              title={step.title}
              description={step.description}
              delay={i * 150}
            />
          ))
        }
      </div>
    </div>
  </Container>
</section>
