---
import Container from "./ui/Container.astro";
import SectionHeading from "./ui/SectionHeading.astro";
import StepCard from "./StepCard.astro";

const steps = [
  {
    title: "Connect",
    description:
      "Point G8Stack to your API gateway instance. Automatic discovery syncs your existing services, routes, and plugins.",
  },
  {
    title: "Configure",
    description:
      "Manage everything through the web UI — subscriptions, API keys, rate limits, approval workflows, and security policies.",
  },
  {
    title: "Scale",
    description:
      "Monitor your APIs with real-time analytics, enforce governance with audit trails, and onboard teams with self-service portals.",
  },
];
---

<section id="how-it-works" class="py-24 lg:py-32 relative">
  <!-- Background accent -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-500/[0.02] to-transparent pointer-events-none"
  >
  </div>

  <Container class="relative">
    <SectionHeading
      label="How It Works"
      title='Three steps to <span class="text-gradient">API gateway mastery</span>'
      description="Get up and running with G8Stack in minutes, not days."
    />

    <div class="relative max-w-4xl mx-auto">
      <!-- Connector line -->
      <div
        class="hidden md:block absolute top-8 left-1/6 right-1/6 h-0.5 bg-gradient-to-r from-blue-500/20 via-violet-500/40 to-blue-500/20"
      >
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
        {
          steps.map((step, i) => (
            <StepCard
              step={i + 1}
              title={step.title}
              description={step.description}
              delay={i * 150}
            />
          ))
        }
      </div>
    </div>
  </Container>
</section>
